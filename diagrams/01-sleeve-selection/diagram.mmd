flowchart TD
    Start([Meth запрашивает новое тело]) --> A[Sleeve Broker получает спецификацию]
    A --> B[Параметры: рост/вес/пол/возраст]
    B --> C[Особые требования: боевые навыки, физическая форма]
    C --> D[Поиск в архивах клонов]
    D --> E{Тело в наличии?}
    
    E -->|Нет| F[Инициация культивирования]
    F --> G[Выбор донора ДНК]
    G --> H[Запуск культивирования]
    H --> I[Ожидание 4-8 месяцев]
    I --> J[Тело готово]
    
    E -->|Да| J
    
    J --> K[Проверка визуальных параметров]
    K --> L{Соответствует спецификации?}
    L -->|Нет| M[Отказ — параметры не те]
    M --> D
    
    L -->|Да| N[Медицинская проверка]
    N --> O[Анализ крови и органов]
    O --> P[ЭКГ и кардиограмма]
    P --> Q{Болезни обнаружены?}
    Q -->|Да| R[Отказ — поиск другого]
    R --> D
    
    Q -->|Нет| S[Нейро-маппинг]
    S --> T[Сканирование нейронных связей]
    T --> U{Совместимо со стеком Meth?}
    U -->|Нет| V[Отказ — несовместимость]
    V --> D
    
    U -->|Да| W[Проверка на наследие]
    W --> X[Сканирование остаточных паттернов]
    X --> Y{Остаточные воспоминания?}
    Y -->|Да| Z[Нейро-очистка]
    Z --> AA[Изоляция чужих нейронных связей]
    AA --> AB{Очистка успешна?}
    AB -->|Нет| V
    AB -->|Да| AC
    
    Y -->|Нет| AC[Физиологическая подготовка]
    Z --> AC
    
    AC --> AD[Приведение веса к целевому]
    AD --> AE[Тренировка мышц до базового тонуса]
    AE --> AF[Фармакологическая подготовка]
    AF --> AG[Введение адаптогенов для интеграции]
    
    AG --> AH[Создание нейрального разъёма]
    AH --> AI[Калибровка разъёма C1-C2]
    AI --> AJ{Калибровка точная?}
    AJ -->|Нет| AK[Перекалибровка]
    AK --> AI
    
    AJ -->|Да| AL[Тестовое подключение стека-заглушки]
    AL --> AM{Соединение стабильно?}
    AM -->|Нет| AN[Диагностика разъёма]
    AN --> AO{Проблема решаема?}
    AO -->|Нет| AP[Маркировка как брак]
    AP --> D
    
    AO -->|Да| AQ[Ремонт разъёма]
    AQ --> AL
    
    AM -->|Да| AR[Резервирование тела]
    AK --> AR
    
    AR --> AS[Блокировка в инвентаре]
    AS --> AT[Фото/видео фиксация 360 градусов]
    AT --> AU[Документирование всех параметров]
    AU --> AV[Создание протокола интеграции]
    AV --> AW[Синхронизация с графиком Meth]
    AW --> AX[Уведомление Needlecaster]
    AX --> End([Sleeve готов к needlecast])
    
    style Start fill:#e1f5fe
    style End fill:#e8f5e9
    style E fill:#fff3e0
    style L fill:#fff3e0
    style Q fill:#fff3e0
    style U fill:#fff3e0
    style Y fill:#fff3e0
    style AB fill:#fff3e0
    style AJ fill:#fff3e0
    style AM fill:#fff3e0
    style AO fill:#fff3e0
