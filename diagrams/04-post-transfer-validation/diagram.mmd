flowchart TD
    Start([Meth после needlecast]) --> A[Psychosurgeon получает протокол]
    A --> B[Начало 72-часового наблюдения]
    
    B --> C[Этап 1: ЭЭГ мониторинг]
    C --> D{Мозговая активность норма?}
    D -->|Нет| E[Анализ аномалий]
    E --> F{Критично?}
    F -->|Да| G[Корректировка стека]
    G --> End1([Возврат к Needlecaster])
    
    F -->|Нет| H[Документирование]
    H --> I
    
    D -->|Да| I[Этап 2: Тест идентичности]
    I --> J{Личность сохранена?}
    J -->|Нет| K[Оценка изменений]
    K --> L{Критично?}
    L -->|Да| M[Терапия или корректировка]
    M --> End2([Возврат к Needlecaster])
    
    L -->|Нет| N
    J -->|Да| N[Этап 3: Тест навыков]
    K --> N
    
    N --> O{Навыки работают?}
    O -->|Нет| P[Диагностика интеграции]
    P --> Q{Решаемо?}
    Q -->|Нет| R[Корректировка навыков]
    R --> End3([Возврат к Needlecaster])
    
    Q -->|Да| S
    O -->|Да| S[Этап 4: Поведенческие тесты]
    P --> S
    
    S --> T{Поведение стабильно?}
    T -->|Нет| U[Анализ характера]
    U --> V{Ожидаемые изменения?}
    V -->|Нет| W[Оценка нежелательных]
    W --> X{Критично?}
    X -->|Да| Y[Корректировка характера]
    Y --> End4([Возврат к Needlecaster])
    
    X -->|Нет| Z
    V -->|Да| Z[Этап 5: Физиологические тесты]
    W --> Z
    
    Z --> AA{Физиология совместима?}
    AA -->|Нет| AB[Диагностика конфликта]
    AB --> AC{Разрешимый?}
    AC -->|Нет| AD[Смена sleeve]
    AD --> End5([Возврат к Sleeve Broker])
    
    AC -->|Да| AE
    AA -->|Да| AE[Этап 6: Стресс-тест]
    AB --> AE
    
    AE --> AF{Системы стабильны?}
    AF -->|Нет| AG[Анализ узких мест]
    AG --> AH{Устранимо?}
    AH -->|Нет| AI[Документирование ограничений]
    AI --> AJ
    
    AH -->|Да| AJ[Сбор результатов]
    AF -->|Да| AJ
    
    AJ --> AK[Анализ данных]
    AK --> AL{Все критерии пройдены?}
    AL -->|Нет| AM[Определение причин]
    AM --> AN{Исправимо?}
    AN -->|Да| AO[План корректировок]
    AO --> End6([Возврат на этап корректировки])
    
    AN -->|Нет| AP[Окончательный отказ]
    AP --> End7([Закрытие без сертификации])
    
    AL -->|Да| AQ[Формирование отчёта]
    AQ --> AR[Сертификат совместимости]
    AR --> AS[Выдача Meth]
    AS --> AT[Обновление досье]
    AT --> End8([Meth сертифицирован, клиника завершена])
    
    style Start fill:#e1f5fe
