flowchart TD
    Start([Meth прибывает в клинику]) --> A[Needlecaster готовит операционную]
    A --> B[Местная анестезия затылка]
    B --> C[Хирургический доступ C1-C2]
    C --> D[Извлечение стека]
    
    D --> E[Проверка физической целостности]
    E --> F{Повреждения?}
    F -->|Да| G[Экстренное восстановление]
    G --> H{Успех?}
    H -->|Нет| I[Real Death — копия из бэкапа]
    H -->|Да| J
    
    F -->|Нет| J[Квантовое сканирование DHF]
    G --> J
    
    J --> K{Данные целостны?}
    K -->|Нет| L[Сравнение с бэкапом]
    L --> M{Бэкап актуален?}
    M -->|Нет| N[Потеря данных — документирование]
    M -->|Да| O[Восстановление из бэкапа]
    O --> J
    
    K -->|Да| P[Создание резервной копии]
    L --> P
    
    P --> Q[Квантовое шифрование]
    Q --> R[Сохранение в хранилище]
    
    R --> S[Настройка needlecast]
    S --> T[Синхронизация с sleeve]
    T --> U[Калибровка частот]
    
    U --> V{Калибровка успешна?}
    V -->|Нет| W[Перекалибровка]
    W --> T
    
    V -->|Да| X[Стек готов к переносу]
    X --> End([Ожидание операционной для sleeve])
    
    style Start fill:#e1f5fe
    style End fill:#e8f5e9
    style F fill:#fff3e0
    style H fill:#fff3e0
    style K fill:#fff3e0
    style M fill:#fff3e0
    style V fill:#fff3e0
