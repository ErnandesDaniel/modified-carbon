// Общие стили для всех документов проекта
// Использование: #import "styles.typ": *

// ============================================
// НАСТРОЙКИ СТРАНИЦЫ
// ============================================

// Поля страницы: верхнее/нижнее 2см, левое 2.5см (для переплета), правое 2см
#set page(
  margin: (top: 2cm, bottom: 2cm, left: 2.5cm, right: 2cm),
  // Нумерация страниц внизу по центру
  numbering: "1",
)

// ============================================
// НАСТРОЙКИ ШРИФТА
// ============================================

// Основной шрифт документа - Arial 12pt
// lang: "ru" - для правильной типографики русского языка
#set text(
  font: "Arial",
  size: 12pt,
  lang: "ru",
)

// ============================================
// НАСТРОЙКИ ПАРАГРАФОВ
// ============================================

// justify: true - выравнивание по ширине
// leading: 1.5em - межстрочный интервал 1.5
// first-line-indent: 1.25cm - отступ первой строки абзаца (красная строка)
#set par(
  justify: true,
  leading: 1.5em,
  first-line-indent: 1.25cm,
)

// ============================================
// НАСТРОЙКИ ЗАГОЛОВКОВ
// ============================================

// Нумерация заголовков в формате 1.1.1 (глава.раздел.подраздел)
#set heading(
  numbering: "1.1.1",
)

// Стили для заголовков первого уровня (Глава 1, Глава 2)
// Размер 16pt, жирный, отступы сверху и снизу
#show heading.where(level: 1): it => {
  set text(size: 16pt, weight: "bold")
  block(above: 1.5em, below: 1em, it)
}

// Стили для заголовков второго уровня (1.1, 1.2)
// Размер 14pt, жирный
#show heading.where(level: 2): it => {
  set text(size: 14pt, weight: "bold")
  block(above: 1.2em, below: 0.8em, it)
}

// Стили для заголовков третьего уровня (1.1.1, 1.1.2)
// Размер 12pt (как основной текст), но жирный
#show heading.where(level: 3): it => {
  set text(size: 12pt, weight: "bold")
  block(above: 1em, below: 0.6em, it)
}

// ============================================
// ФУНКЦИИ ДЛЯ ЗАГОЛОВКОВ
// ============================================

// Функция для создания главы (раздела) первого уровня
// Например: #chapter[1][Introduction (Введение)]
// Результат: "1 Introduction (Введение)"
#let chapter(number, title) = {
  heading(level: 1, numbering: none)[#number #title]
}

// Функция для создания секции (подраздела) второго уровня
// Например: #section[1.1][Purpose (Назначение)]
// Результат: "1.1 Purpose (Назначение)"
#let section(number, title) = {
  heading(level: 2, numbering: none)[#number #title]
}

// Функция для создания подсекции третьего уровня
// Например: #subsection[1.1.1][Подраздел]
#let subsection(number, title) = {
  heading(level: 3, numbering: none)[#number #title]
}

// Функция для создания подсекции четвертого уровня
// Например: #subsubsection[1.1.1.1][Под-подраздел]
#let subsubsection(number, title) = {
  heading(level: 4, numbering: none)[#number #title]
}

// ============================================
// ФУНКЦИЯ ДЛЯ СОЗДАНИЯ ТАБЛИЦ
// ============================================

// Унифицированная функция для создания таблиц в документах
// columns - массив ширин колонок, например (1fr, 2fr)
// ...args - содержимое таблицы (ячейки)
//
// Пример использования:
// #doctable(
//   (1fr, 2fr),
//   table-header[Заголовок 1], table-header[Заголовок 2],
//   [Ячейка 1], [Ячейка 2],
// )
#let doctable(columns, ..args) = {
  table(
    columns: columns,
    // Заголовки по центру, данные по левому краю
    align: (col, row) => if row == 0 { center } else { left },
    stroke: 0.5pt,
    inset: 8pt,
    ..args
  )
}

// ============================================
// ФУНКЦИЯ ДЛЯ ЗАГОЛОВКОВ ТАБЛИЦ
// ============================================

// Создаёт жирный текст для заголовков таблиц
// Пример: table-header[Название колонки]
#let table-header = text.with(weight: "bold")

// ============================================
// ФУНКЦИЯ ДЛЯ ЗАГОЛОВКА ДОКУМЕНТА
// ============================================

// Создаёт красивый заголовок документа по центру
// title - основное название (крупное, жирное)
// subtitle - подзаголовок (опционально, поменьше)
//
// Пример: #doc-title("Vision", subtitle: "Концепция")
#let doc-title(title, subtitle: none) = {
  align(center)[
    #text(size: 18pt, weight: "bold")[#title]
    #if subtitle != none {
      linebreak()
      text(size: 14pt)[#subtitle]
    }
  ]
  v(1.5em)  // Отступ после заголовка
}

// ============================================
// ФУНКЦИЯ ДЛЯ PLACEHOLDER ТЕКСТА
// ============================================

// Создаёт серый курсивный текст для шаблонов/заглушек
// Используется для текста, который нужно заменить реальным содержанием
// Пример: #placeholder[Укажите назначение документа]
//
// Особенности:
// - Курсив (italic)
// - Серый цвет (темнее основного на 30%)
// - В квадратных скобках для наглядности
#let placeholder(content) = {
  text(style: "italic", fill: gray.darken(30%))[[#content]]
}

// ============================================
// ФУНКЦИЯ ДЛЯ СОЗДАНИЯ СТРОК ТАБЛИЦ
// ============================================

// Создаёт строку таблицы с переводом
// Используется для таблиц Problem Statement и подобных
// где есть текст на английском и русском
//
// Пример: #table-row("The problem of", "Проблема", "Опишите проблему")
#let table-row(en-text, ru-text, placeholder-text) = {
  ([#en-text #linebreak() (#ru-text)], [#placeholder[#placeholder-text]])
}
